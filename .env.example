# Canadian Data Observatory - Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# --- Grafana ---
CDO_GRAFANA_PORT=3000
CDO_GRAFANA_ADMIN_USER=admin
CDO_GRAFANA_ADMIN_PASSWORD=admin

# --- Prometheus ---
CDO_PROMETHEUS_PORT=9090

# --- PostgreSQL ---
CDO_POSTGRES_PORT=5432
CDO_POSTGRES_DB=cdo
CDO_POSTGRES_USER=cdo
CDO_POSTGRES_PASSWORD=cdo_secret

# --- Redis ---
CDO_REDIS_PORT=6379

# --- Exporter ---
CDO_EXPORTER_PORT=8000
CDO_LOG_LEVEL=INFO

# --- API Keys ---
# Vancouver Open Data API key (optional, increases rate limits)
CDO_VANCOUVER_API_KEY=
