{
  "uid": "cdo-housing",
  "title": "Housing Market",
  "description": "Canadian housing market indicators from Statistics Canada and CMHC",
  "tags": ["cdo", "housing", "canada"],
  "timezone": "America/Toronto",
  "editable": true,
  "refresh": "24h",
  "time": {
    "from": "now-5y",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cma",
        "type": "custom",
        "label": "CMA",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": ["$__all"] },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "Toronto", "value": "Toronto", "selected": false },
          { "text": "Vancouver", "value": "Vancouver", "selected": false },
          { "text": "Montreal", "value": "Montreal", "selected": false },
          { "text": "Calgary", "value": "Calgary", "selected": false },
          { "text": "Edmonton", "value": "Edmonton", "selected": false },
          { "text": "Ottawa-Gatineau", "value": "Ottawa-Gatineau", "selected": false },
          { "text": "Winnipeg", "value": "Winnipeg", "selected": false },
          { "text": "Halifax", "value": "Halifax", "selected": false },
          { "text": "Victoria", "value": "Victoria", "selected": false },
          { "text": "Hamilton", "value": "Hamilton", "selected": false }
        ],
        "query": "Toronto,Vancouver,Montreal,Calgary,Edmonton,Ottawa-Gatineau,Winnipeg,Halifax,Victoria,Hamilton"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Housing Price Index by CMA",
      "description": "New Housing Price Index (2017=100) across major CMAs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_price_index{cma=~\"$cma\"}",
          "legendFormat": "{{ cma }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "axisSoftMin": 0
          },
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Avg Price - Toronto",
      "description": "Average residential property price",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_avg_price_dollars{cma=\"Toronto\"}",
          "legendFormat": "Toronto",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyCAD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "orange", "value": 800000 },
              { "color": "red", "value": 1000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Avg Price - Vancouver",
      "description": "Average residential property price",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_avg_price_dollars{cma=\"Vancouver\"}",
          "legendFormat": "Vancouver",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyCAD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 1000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Avg Price - Montreal",
      "description": "Average residential property price",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_avg_price_dollars{cma=\"Montreal\"}",
          "legendFormat": "Montreal",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyCAD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400000 },
              { "color": "red", "value": 700000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Housing Starts by Type",
      "description": "Housing starts stacked by single-detached and multi-unit",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_starts_total{cma=~\"$cma\", type=\"single\"}",
          "legendFormat": "Single - {{ cma }}",
          "refId": "A"
        },
        {
          "expr": "cdo_housing_starts_total{cma=~\"$cma\", type=\"multi\"}",
          "legendFormat": "Multi - {{ cma }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": true,
            "axisSoftMin": 0
          },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Starts by CMA",
      "description": "Total housing starts by CMA",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_starts_total{type=\"all\"}",
          "legendFormat": "{{ cma }}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Vacancy Rates by CMA",
      "description": "Rental vacancy rates across major CMAs",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_vacancy_rate_percent",
          "legendFormat": "{{ cma }}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd", "fixedColor": "green" },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      }
    },
    {
      "id": 8,
      "title": "Average Rent by CMA",
      "description": "Average monthly rent by CMA and bedroom count",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_avg_rent_dollars{cma=~\"$cma\"}",
          "legendFormat": "{{ cma }} - {{ bedrooms }}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyCAD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red", "value": 2500 }
            ]
          },
          "custom": {
            "align": "auto",
            "displayMode": "color-background-solid"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Value", "desc": true }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "cma": "CMA", "bedrooms": "Bedrooms", "Value": "Avg Rent ($)" }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "Price-to-Income Ratio by CMA",
      "description": "Housing affordability: average price divided by median income",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_price_to_income_ratio{cma=~\"$cma\"}",
          "legendFormat": "{{ cma }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "axisSoftMin": 0
          },
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 8 },
              { "color": "red", "value": 12 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
