{
  "uid": "cdo-home",
  "title": "Canadian Data Observatory",
  "description": "National overview dashboard with key indicators across all domains",
  "tags": ["cdo", "home", "overview", "canada"],
  "timezone": "America/Toronto",
  "editable": true,
  "refresh": "1h",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "GDP",
      "description": "Latest Gross Domestic Product (millions CAD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_economy_gdp_millions{province=\"CA\"}",
          "legendFormat": "GDP",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "CPI",
      "description": "Latest Consumer Price Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_economy_cpi_index{province=\"CA\", basket=\"All-items\"}",
          "legendFormat": "CPI",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 130 },
              { "color": "red", "value": 150 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Unemployment",
      "description": "National unemployment rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_economy_unemployment_rate_percent{province=\"CA\"}",
          "legendFormat": "Unemployment",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "orange", "value": 8 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "Population",
      "description": "Total Canadian population estimate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_demographics_population_total{province=\"CA\"}",
          "legendFormat": "Population",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Avg Home Price",
      "description": "Average residential home price (Toronto)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_housing_avg_price_dollars{cma=\"Toronto\"}",
          "legendFormat": "Avg Price",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyCAD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Temperature (Ottawa)",
      "description": "Current temperature in the national capital",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_climate_temperature_celsius{city=\"Ottawa\"}",
          "legendFormat": "Ottawa Temp",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "celsius",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-blue", "value": null },
              { "color": "blue", "value": -20 },
              { "color": "light-blue", "value": -5 },
              { "color": "green", "value": 5 },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 35 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "Crime Severity Index",
      "description": "National Crime Severity Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_crime_severity_index{province=\"CA\", type=\"total\"}",
          "legendFormat": "CSI",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 8,
      "title": "Immigration",
      "description": "Annual permanent residents admitted (national)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_immigration_permanent_residents_total{province=\"CA\"}",
          "legendFormat": "Immigration",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 9,
      "title": "Data Freshness",
      "description": "Last update timestamps for each data source",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "cdo_economy_last_update_timestamp",
          "legendFormat": "Economy",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "cdo_climate_last_update_timestamp",
          "legendFormat": "Climate",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "cdo_immigration_last_update_timestamp",
          "legendFormat": "Immigration",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "cdo_demographics_last_update_timestamp",
          "legendFormat": "Demographics",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ]
    },
    {
      "id": 10,
      "title": "Attribution",
      "description": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 14 },
      "datasource": null,
      "targets": [],
      "options": {
        "mode": "markdown",
        "content": "Contains information licensed under the [Open Government Licence - Canada](https://open.canada.ca/en/open-government-licence-canada). Data sourced from Statistics Canada, Environment and Climate Change Canada, and other federal agencies."
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
